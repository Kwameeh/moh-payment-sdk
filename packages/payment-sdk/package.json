{
  "name": "@kwameeh_1/payment-sdk",
  "version": "1.2.3",
  "description": "MOH Payment Gateway SDK for frontend applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
